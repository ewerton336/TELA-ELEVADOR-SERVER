{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=postgres;Port=5432;Database=elevador_db;Username=elevador_user;Password=elevador_password"
  },
  "Jwt": {
    "Key": "your-super-secret-key-change-this-in-production",
    "Issuer": "elevador-api",
    "Audience": "elevador-app",
    "ExpirationMinutes": 60
  }
}
